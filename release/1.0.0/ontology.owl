<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/city-kgs/restaurants/"
     xml:base="https://w3id.org/city-kgs/restaurants/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:pr="https://w3id.org/city-kgs/restaurants/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="https://w3id.org/city-kgs/restaurants">
        <owl:versionIRI rdf:resource="https://w3id.org/city-kgs/restaurants/1.0.0"/>
        <dc:creator>Ernesto Jimenez Ruiz</dc:creator>
        <owl:versionInfo>Version 02/03/2024</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/city-kgs/restaurants/amountCurrency -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/amountCurrency">
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/ItemValue"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Currency"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/containsAdress -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/containsAdress">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/containsLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Address"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/containsCity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/containsCity">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/containsLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/City"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/containsLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/containsLocation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/city-kgs/restaurants/locatedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/Location"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Location"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/containsState -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/containsState">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/containsLocation"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/State"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/hasIngredient -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/hasIngredient">
        <owl:inverseOf rdf:resource="https://w3id.org/city-kgs/restaurants/isIngredientOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/Food"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Ingredient"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/hasValue -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/hasValue"/>
    


    <!-- https://w3id.org/city-kgs/restaurants/isIngredientOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/isIngredientOf">
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/Ingredient"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Food"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/locatedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/locatedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/Location"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Location"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/locatedInAddress -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/locatedInAddress">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/locatedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Address"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/locatedInCity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/locatedInCity">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/locatedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/City"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/locatedInCountry -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/locatedInCountry">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/locatedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/Country"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/locatedInState -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/locatedInState">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/locatedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/city-kgs/restaurants/State"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/servedIn -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/servedIn">
        <owl:inverseOf rdf:resource="https://w3id.org/city-kgs/restaurants/serves"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/servedInRestaurant -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/servedInRestaurant">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/servedIn"/>
        <owl:inverseOf rdf:resource="https://w3id.org/city-kgs/restaurants/servesMenuItem"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/serves -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/serves">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/servesMenuItem -->

    <owl:ObjectProperty rdf:about="https://w3id.org/city-kgs/restaurants/servesMenuItem">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/serves"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/city-kgs/restaurants/amount -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/city-kgs/restaurants/amount">
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/ItemValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/firstLineAddress -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/city-kgs/restaurants/firstLineAddress">
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/Address"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/itemName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/city-kgs/restaurants/itemName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/name"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/name -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/city-kgs/restaurants/name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/postCode -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/city-kgs/restaurants/postCode">
        <rdfs:domain rdf:resource="https://w3id.org/city-kgs/restaurants/Address"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/city-kgs/restaurants/restaurantName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/city-kgs/restaurants/restaurantName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/city-kgs/restaurants/name"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/city-kgs/restaurants/Address -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Address">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Location"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/city-kgs/restaurants/locatedInCity"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/city-kgs/restaurants/City"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/city-kgs/restaurants/firstLineAddress"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/city-kgs/restaurants/postCode"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Address</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/AmericanPizza -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/AmericanPizza">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/PizzaByStyle"/>
        <rdfs:label>American pizza</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/AmericanRestaurant -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/AmericanRestaurant">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Restaurant"/>
        <rdfs:label>American restaurant</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Anchovies -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Anchovies">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/SeaFood"/>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Artichokes -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Artichokes">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Vegetable"/>
        <rdfs:label>Artichoke</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/AsianRestaurant -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/AsianRestaurant">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Restaurant"/>
        <rdfs:label>Asian restaurant</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Bacon -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Bacon">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Meat"/>
        <rdfs:label>Bacon</rdfs:label>
        <skos:altLabel>Pancetta</skos:altLabel>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Bakery -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Bakery">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Restaurant"/>
        <rdfs:label>Bakery</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Bar -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Bar">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/BarsPubsClubs"/>
        <rdfs:label>Bar</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BarAndGrill -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BarAndGrill">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Restaurant"/>
        <rdfs:label>Bar and Grill</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BarbecuePizza -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BarbecuePizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/city-kgs/restaurants/Pizza"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/city-kgs/restaurants/hasIngredient"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/city-kgs/restaurants/BarbecueSauce"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/PizzaByIngredient"/>
        <rdfs:label>Barbecue pizza</rdfs:label>
        <skos:altLabel>BBQ pizza</skos:altLabel>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BarbecueSauce -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BarbecueSauce">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Sauce"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/VeganIngredient"/>
        <rdfs:label>Barbecue sause</rdfs:label>
        <skos:altLabel>BBQ sauce</skos:altLabel>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BarsPubsClubs -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BarsPubsClubs">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Restaurant"/>
        <rdfs:label>Bars, pubs and clubs</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Basil -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Basil">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Herbs"/>
        <rdfs:label>Basil</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Beans -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Beans">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Seeds"/>
        <rdfs:label>Beans</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BeansPizza -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BeansPizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/city-kgs/restaurants/Pizza"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/city-kgs/restaurants/hasIngredient"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/city-kgs/restaurants/Beans"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/PizzaByIngredient"/>
        <rdfs:label>Beans pizza</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Beef -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Beef">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Meat"/>
        <rdfs:label>Beef</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BeerPlace -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BeerPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/BarsPubsClubs"/>
        <rdfs:label>Beer place</rdfs:label>
        <skos:altLabel>Beer tavern</skos:altLabel>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BlackOlives -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BlackOlives">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Olives"/>
        <rdfs:label>Black olives</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BlueCheese -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BlueCheese">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Cheese"/>
        <rdfs:label>Blue cheese</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Broccoli -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Broccoli">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Vegetable"/>
        <rdfs:label>Broccoli</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/BurgerPlace -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/BurgerPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Restaurant"/>
        <rdfs:label>Burger place</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/ButternutSquash -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/ButternutSquash">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/WinterSquash"/>
        <rdfs:label>ButternutSquash</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/CalifornianPizza -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/CalifornianPizza">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/AmericanPizza"/>
        <rdfs:label>Californian pizza</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Capers -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Capers">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Vegetable"/>
        <rdfs:label>Capers</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Carrot -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Carrot">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/RootVegetable"/>
        <rdfs:label>Carrot</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Cheddar -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Cheddar">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Cheese"/>
        <rdfs:label>Cheddar</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/Cheese -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/Cheese">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/VegetarianIngredient"/>
    </owl:Class>
    


    <!-- https://w3id.org/city-kgs/restaurants/CherryTomato -->

    <owl:Class rdf:about="https://w3id.org/city-kgs/restaurants/CherryTomato">
        <rdfs:subClassOf rdf:resource="https://w3id.org/city-kgs/restaurants/Tomato"/>
        <rdfs:label>Cherry tomato</rdfs:label>
