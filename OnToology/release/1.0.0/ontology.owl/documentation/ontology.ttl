@prefix : <https://w3id.org/city-kgs/restaurants#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/city-kgs/restaurants#> .

<https://w3id.org/city-kgs/restaurants> rdf:type owl:Ontology ;
                                         owl:versionIRI <https://w3id.org/city-kgs/restaurants/1.0.0> ;
                                         <http://purl.org/dc/elements/1.1/creator> "Ernesto Jimenez Ruiz" ;
                                         owl:versionInfo "Version 02/03/2024" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/city-kgs/restaurants/amountCurrency
<https://w3id.org/city-kgs/restaurants/amountCurrency> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://w3id.org/city-kgs/restaurants/ItemValue> ;
                                                       rdfs:range <https://w3id.org/city-kgs/restaurants/Currency> .


###  https://w3id.org/city-kgs/restaurants/containsAdress
<https://w3id.org/city-kgs/restaurants/containsAdress> rdf:type owl:ObjectProperty ;
                                                       rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/containsLocation> ;
                                                       rdfs:range <https://w3id.org/city-kgs/restaurants/Address> .


###  https://w3id.org/city-kgs/restaurants/containsCity
<https://w3id.org/city-kgs/restaurants/containsCity> rdf:type owl:ObjectProperty ;
                                                     rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/containsLocation> ;
                                                     rdfs:range <https://w3id.org/city-kgs/restaurants/City> .


###  https://w3id.org/city-kgs/restaurants/containsLocation
<https://w3id.org/city-kgs/restaurants/containsLocation> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf owl:topObjectProperty ;
                                                         owl:inverseOf <https://w3id.org/city-kgs/restaurants/locatedIn> ;
                                                         rdf:type owl:TransitiveProperty ;
                                                         rdfs:domain <https://w3id.org/city-kgs/restaurants/Location> ;
                                                         rdfs:range <https://w3id.org/city-kgs/restaurants/Location> .


###  https://w3id.org/city-kgs/restaurants/containsState
<https://w3id.org/city-kgs/restaurants/containsState> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/containsLocation> ;
                                                      rdfs:range <https://w3id.org/city-kgs/restaurants/State> .


###  https://w3id.org/city-kgs/restaurants/hasIngredient
<https://w3id.org/city-kgs/restaurants/hasIngredient> rdf:type owl:ObjectProperty ;
                                                      owl:inverseOf <https://w3id.org/city-kgs/restaurants/isIngredientOf> ;
                                                      rdfs:domain <https://w3id.org/city-kgs/restaurants/Food> ;
                                                      rdfs:range <https://w3id.org/city-kgs/restaurants/Ingredient> .


###  https://w3id.org/city-kgs/restaurants/hasValue
<https://w3id.org/city-kgs/restaurants/hasValue> rdf:type owl:ObjectProperty .


###  https://w3id.org/city-kgs/restaurants/isIngredientOf
<https://w3id.org/city-kgs/restaurants/isIngredientOf> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://w3id.org/city-kgs/restaurants/Ingredient> ;
                                                       rdfs:range <https://w3id.org/city-kgs/restaurants/Food> .


###  https://w3id.org/city-kgs/restaurants/locatedIn
<https://w3id.org/city-kgs/restaurants/locatedIn> rdf:type owl:ObjectProperty ,
                                                           owl:TransitiveProperty ;
                                                  rdfs:domain <https://w3id.org/city-kgs/restaurants/Location> ;
                                                  rdfs:range <https://w3id.org/city-kgs/restaurants/Location> .


###  https://w3id.org/city-kgs/restaurants/locatedInAddress
<https://w3id.org/city-kgs/restaurants/locatedInAddress> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/locatedIn> ;
                                                         rdf:type owl:FunctionalProperty ;
                                                         rdfs:range <https://w3id.org/city-kgs/restaurants/Address> .


###  https://w3id.org/city-kgs/restaurants/locatedInCity
<https://w3id.org/city-kgs/restaurants/locatedInCity> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/locatedIn> ;
                                                      rdf:type owl:FunctionalProperty ;
                                                      rdfs:range <https://w3id.org/city-kgs/restaurants/City> .


###  https://w3id.org/city-kgs/restaurants/locatedInCountry
<https://w3id.org/city-kgs/restaurants/locatedInCountry> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/locatedIn> ;
                                                         rdf:type owl:FunctionalProperty ;
                                                         rdfs:range <https://w3id.org/city-kgs/restaurants/Country> .


###  https://w3id.org/city-kgs/restaurants/locatedInState
<https://w3id.org/city-kgs/restaurants/locatedInState> rdf:type owl:ObjectProperty ;
                                                       rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/locatedIn> ;
                                                       rdf:type owl:FunctionalProperty ;
                                                       rdfs:range <https://w3id.org/city-kgs/restaurants/State> .


###  https://w3id.org/city-kgs/restaurants/servedIn
<https://w3id.org/city-kgs/restaurants/servedIn> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf <https://w3id.org/city-kgs/restaurants/serves> .


###  https://w3id.org/city-kgs/restaurants/servedInRestaurant
<https://w3id.org/city-kgs/restaurants/servedInRestaurant> rdf:type owl:ObjectProperty ;
                                                           rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/servedIn> ;
                                                           owl:inverseOf <https://w3id.org/city-kgs/restaurants/servesMenuItem> .


###  https://w3id.org/city-kgs/restaurants/serves
<https://w3id.org/city-kgs/restaurants/serves> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf owl:topObjectProperty .


###  https://w3id.org/city-kgs/restaurants/servesMenuItem
<https://w3id.org/city-kgs/restaurants/servesMenuItem> rdf:type owl:ObjectProperty ;
                                                       rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/serves> .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/city-kgs/restaurants/amount
<https://w3id.org/city-kgs/restaurants/amount> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://w3id.org/city-kgs/restaurants/ItemValue> ;
                                               rdfs:range xsd:double .


###  https://w3id.org/city-kgs/restaurants/firstLineAddress
<https://w3id.org/city-kgs/restaurants/firstLineAddress> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <https://w3id.org/city-kgs/restaurants/Address> ;
                                                         rdfs:range xsd:string .


###  https://w3id.org/city-kgs/restaurants/itemName
<https://w3id.org/city-kgs/restaurants/itemName> rdf:type owl:DatatypeProperty ;
                                                 rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/name> ;
                                                 rdfs:range xsd:string .


###  https://w3id.org/city-kgs/restaurants/name
<https://w3id.org/city-kgs/restaurants/name> rdf:type owl:DatatypeProperty ;
                                             rdfs:range xsd:string .


###  https://w3id.org/city-kgs/restaurants/postCode
<https://w3id.org/city-kgs/restaurants/postCode> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <https://w3id.org/city-kgs/restaurants/Address> ;
                                                 rdfs:range xsd:string .


###  https://w3id.org/city-kgs/restaurants/restaurantName
<https://w3id.org/city-kgs/restaurants/restaurantName> rdf:type owl:DatatypeProperty ;
                                                       rdfs:subPropertyOf <https://w3id.org/city-kgs/restaurants/name> .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/city-kgs/restaurants/Address
<https://w3id.org/city-kgs/restaurants/Address> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Location> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://w3id.org/city-kgs/restaurants/locatedInCity> ;
                                                                  owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/City>
                                                                ] ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://w3id.org/city-kgs/restaurants/firstLineAddress> ;
                                                                  owl:someValuesFrom xsd:string
                                                                ] ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://w3id.org/city-kgs/restaurants/postCode> ;
                                                                  owl:someValuesFrom xsd:string
                                                                ] ;
                                                rdfs:label "Address" .


###  https://w3id.org/city-kgs/restaurants/AmericanPizza
<https://w3id.org/city-kgs/restaurants/AmericanPizza> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/PizzaByStyle> ;
                                                      rdfs:label "American pizza" .


###  https://w3id.org/city-kgs/restaurants/AmericanRestaurant
<https://w3id.org/city-kgs/restaurants/AmericanRestaurant> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Restaurant> ;
                                                           rdfs:label "American restaurant" .


###  https://w3id.org/city-kgs/restaurants/Anchovies
<https://w3id.org/city-kgs/restaurants/Anchovies> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/SeaFood> .


###  https://w3id.org/city-kgs/restaurants/Artichokes
<https://w3id.org/city-kgs/restaurants/Artichokes> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Vegetable> ;
                                                   rdfs:label "Artichoke" .


###  https://w3id.org/city-kgs/restaurants/AsianRestaurant
<https://w3id.org/city-kgs/restaurants/AsianRestaurant> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Restaurant> ;
                                                        rdfs:label "Asian restaurant" .


###  https://w3id.org/city-kgs/restaurants/Bacon
<https://w3id.org/city-kgs/restaurants/Bacon> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Meat> ;
                                              rdfs:label "Bacon" ;
                                              <http://www.w3.org/2004/02/skos/core#altLabel> "Pancetta" .


###  https://w3id.org/city-kgs/restaurants/Bakery
<https://w3id.org/city-kgs/restaurants/Bakery> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Restaurant> ;
                                               rdfs:label "Bakery" .


###  https://w3id.org/city-kgs/restaurants/Bar
<https://w3id.org/city-kgs/restaurants/Bar> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/BarsPubsClubs> ;
                                            rdfs:label "Bar" .


###  https://w3id.org/city-kgs/restaurants/BarAndGrill
<https://w3id.org/city-kgs/restaurants/BarAndGrill> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Restaurant> ;
                                                    rdfs:label "Bar and Grill" .


###  https://w3id.org/city-kgs/restaurants/BarbecuePizza
<https://w3id.org/city-kgs/restaurants/BarbecuePizza> rdf:type owl:Class ;
                                                      owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/city-kgs/restaurants/Pizza>
                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty <https://w3id.org/city-kgs/restaurants/hasIngredient> ;
                                                                                                   owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/BarbecueSauce>
                                                                                                 ]
                                                                                               ) ;
                                                                            rdf:type owl:Class
                                                                          ] ;
                                                      rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/PizzaByIngredient> ;
                                                      rdfs:label "Barbecue pizza" ;
                                                      <http://www.w3.org/2004/02/skos/core#altLabel> "BBQ pizza" .


###  https://w3id.org/city-kgs/restaurants/BarbecueSauce
<https://w3id.org/city-kgs/restaurants/BarbecueSauce> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Sauce> ,
                                                                      <https://w3id.org/city-kgs/restaurants/VeganIngredient> ;
                                                      rdfs:label "Barbecue sause" ;
                                                      <http://www.w3.org/2004/02/skos/core#altLabel> "BBQ sauce" .


###  https://w3id.org/city-kgs/restaurants/BarsPubsClubs
<https://w3id.org/city-kgs/restaurants/BarsPubsClubs> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Restaurant> ;
                                                      rdfs:label "Bars, pubs and clubs" .


