                                                                        owl:onProperty <https://w3id.org/city-kgs/restaurants/hasIngredient> ;
                                                                        owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/Mozzarella>
                                                                      ] ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/city-kgs/restaurants/hasIngredient> ;
                                                                        owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/TomatoSauce>
                                                                      ] ;
