###  https://w3id.org/city-kgs/restaurants/City
<https://w3id.org/city-kgs/restaurants/City> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Location> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://w3id.org/city-kgs/restaurants/locatedInCountry> ;
                                                               owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/Country>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://w3id.org/city-kgs/restaurants/locatedInState> ;
                                                               owl:allValuesFrom <https://w3id.org/city-kgs/restaurants/State>
                                                             ] ;
                                             rdfs:label "City" .


