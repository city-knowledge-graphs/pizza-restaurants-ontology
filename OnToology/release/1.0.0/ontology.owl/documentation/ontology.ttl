<https://w3id.org/city-kgs/restaurants/Basil> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Herbs> ;
                                              rdfs:label "Basil" .


###  https://w3id.org/city-kgs/restaurants/Beans
<https://w3id.org/city-kgs/restaurants/Beans> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/Seeds> ;
                                              rdfs:label "Beans" .


###  https://w3id.org/city-kgs/restaurants/BeansPizza
<https://w3id.org/city-kgs/restaurants/BeansPizza> rdf:type owl:Class ;
                                                   owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/city-kgs/restaurants/Pizza>
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <https://w3id.org/city-kgs/restaurants/hasIngredient> ;
                                                                                                owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/Beans>
                                                                                              ]
                                                                                            ) ;
                                                                         rdf:type owl:Class
                                                                       ] ;
                                                   rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/PizzaByIngredient> ;
                                                   rdfs:label "Beans pizza" .


