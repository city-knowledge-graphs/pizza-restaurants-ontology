                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty <https://w3id.org/city-kgs/restaurants/hasIngredient> ;
                                                                                                   owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                                                       owl:unionOf ( <https://w3id.org/city-kgs/restaurants/Garlic>
                                                                                                                                     <https://w3id.org/city-kgs/restaurants/Mozzarella>
                                                                                                                                     <https://w3id.org/city-kgs/restaurants/TomatoSauce>
                                                                                                                                   )
                                                                                                                     ]
                                                                                                 ]
                                                                                               ) ;
                                                                            rdf:type owl:Class
                                                                          ] ;
                                                      rdfs:subClassOf <https://w3id.org/city-kgs/restaurants/NamedPizza> ,
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <https://w3id.org/city-kgs/restaurants/hasIngredient> ;
