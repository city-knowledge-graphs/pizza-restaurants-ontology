                                                                                                                       owl:someValuesFrom <https://w3id.org/city-kgs/restaurants/Spinach>
                                                                                                                     ]
                                                                                                                   ) ;
                                                                                                rdf:type owl:Class
                                                                                              ]
                                                                                            ) ;
